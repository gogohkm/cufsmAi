{
    "name": "stcfsd",
    "displayName": "StCFSD - Cold-Formed Steel Buckling Analysis",
    "description": "Finite Strip Method (FSM) buckling analysis and DSM design for cold-formed steel sections with AI-powered MCP integration",
    "version": "0.1.0",
    "publisher": "Jeil-StructuralEngineering-Consultants",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/gogohkm/cufsmAi"
    },
    "homepage": "https://github.com/gogohkm/cufsmAi#readme",
    "bugs": {
        "url": "https://github.com/gogohkm/cufsmAi/issues"
    },
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Other",
        "Visualization"
    ],
    "keywords": [
        "cold-formed steel",
        "buckling",
        "finite strip method",
        "DSM",
        "structural engineering",
        "StCFSD",
        "section design",
        "MCP"
    ],
    "activationEvents": [],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "stcfsd.openDesigner",
                "title": "StCFSD: Open Section Designer",
                "icon": "$(tools)"
            },
            {
                "command": "stcfsd.newProject",
                "title": "StCFSD: New Project"
            },
            {
                "command": "stcfsd.navigateSection",
                "title": "StCFSD: Navigate Section"
            },
            {
                "command": "stcfsd.refreshProjects",
                "title": "StCFSD: Refresh Projects",
                "icon": "$(refresh)"
            },
            {
                "command": "stcfsd.runAnalysis",
                "title": "Run Analysis",
                "icon": "$(play)"
            }
        ],
        "menus": {
            "view/title": [
                {
                    "command": "stcfsd.openDesigner",
                    "when": "view == stcfsd.projectExplorer",
                    "group": "navigation"
                },
                {
                    "command": "stcfsd.refreshProjects",
                    "when": "view == stcfsd.projectExplorer",
                    "group": "navigation"
                }
            ],
            "view/item/context": [
                {
                    "command": "stcfsd.runAnalysis",
                    "when": "view == stcfsd.projectExplorer && viewItem == section-analysis",
                    "group": "navigation"
                }
            ],
            "commandPalette": [
                {
                    "command": "stcfsd.navigateSection",
                    "when": "false"
                },
                {
                    "command": "stcfsd.runAnalysis",
                    "when": "false"
                }
            ]
        },
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "stcfsd-explorer",
                    "title": "StCFSD",
                    "icon": "media/stcfsd-icon.svg"
                }
            ]
        },
        "views": {
            "stcfsd-explorer": [
                {
                    "id": "stcfsd.projectExplorer",
                    "name": "Section Designer"
                }
            ]
        }
    },
    "scripts": {
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "build:webview": "webpack --config webpack.config.js --mode production",
        "build:mcp": "webpack --config webpack.mcp.config.js --mode production",
        "build": "npm run compile && npm run build:webview && npm run build:mcp",
        "package": "npm run build && vsce package",
        "lint": "eslint src --ext ts",
        "test:webview-contract": "node ./test/webview/design_prepare_contract.js",
        "test:vscode": "npm run compile && node ./test/vscode/runTest.js"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "@types/vscode": "^1.85.0",
        "@vscode/test-electron": "^2.5.2",
        "@vscode/vsce": "^3.7.1",
        "ts-loader": "^9.5.0",
        "typescript": "^5.3.0",
        "webpack": "^5.89.0",
        "webpack-cli": "^5.1.4"
    },
    "dependencies": {
        "@babylonjs/core": "^7.43.2",
        "@modelcontextprotocol/sdk": "^1.29.0",
        "zod": "^4.3.6"
    }
}
