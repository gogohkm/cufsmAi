{
    "name": "cufsm",
    "displayName": "CUFSM - Cold-Formed Steel Buckling Analysis",
    "description": "Finite Strip Method buckling analysis for cold-formed steel sections",
    "version": "0.1.0",
    "publisher": "jeilstructural",
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": ["Other"],
    "activationEvents": [],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "cufsm.openDesigner",
                "title": "CUFSM: Open Section Designer"
            },
            {
                "command": "cufsm.newProject",
                "title": "CUFSM: New Project"
            },
            {
                "command": "cufsm.openProject",
                "title": "CUFSM: Open Project"
            }
        ],
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "cufsm-explorer",
                    "title": "CUFSM",
                    "icon": "media/icon.svg"
                }
            ]
        },
        "views": {
            "cufsm-explorer": [
                {
                    "id": "cufsm.projectExplorer",
                    "name": "Projects"
                }
            ]
        }
    },
    "scripts": {
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "build:webview": "webpack --mode production",
        "build": "npm run compile && npm run build:webview",
        "lint": "eslint src --ext ts"
    },
    "devDependencies": {
        "@types/vscode": "^1.85.0",
        "@types/node": "^20.0.0",
        "typescript": "^5.3.0",
        "webpack": "^5.89.0",
        "webpack-cli": "^5.1.4",
        "ts-loader": "^9.5.0"
    },
    "dependencies": {
        "@babylonjs/core": "^7.43.2"
    }
}
